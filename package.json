{
  "name": "retrogemini",
  "version": "1.1.0",
  "description": "Self-hosted, real-time collaborative retrospectives and team health checks",
  "type": "module",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/uSpreadIt/RetroGeminiCodex.git"
  },
  "keywords": [
    "retrospective",
    "agile",
    "scrum",
    "team",
    "collaboration",
    "health-check",
    "self-hosted"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "docker:build": "docker build -t team-retrospective .",
    "docker:run": "docker run -p 8080:8080 team-retrospective",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "test:e2e": "npx playwright test",
    "ci": "npm run lint && npm run type-check && npm run test && npm run build",
    "prepare": "node -e \"import('husky').catch((e) => { if (e.code !== 'ERR_MODULE_NOT_FOUND' && e.code !== 'MODULE_NOT_FOUND') throw e; })\"",
    "test:e2e:headed": "npx playwright test --headed --project=chromium",
    "test:e2e:debug": "npx playwright test --debug --project=chromium"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "fast-xml-parser": "^5.3.4",
    "qs": ">=6.14.1",
    "tar": ">=7.5.3",
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    }
  },
  "dependencies": {
    "@socket.io/postgres-adapter": "^0.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^5.12.1",
    "socket.io": "^4.8.2",
    "socket.io-client": "^4.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.3"
  }
}
