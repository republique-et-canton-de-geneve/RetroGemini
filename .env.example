# RetroGemini Configuration
# Copy this file to .env and adjust values for your environment
# All variables are optional - the application works with defaults

# =============================================================================
# Server Configuration
# =============================================================================

# Port the server listens on (default: 3000 in dev, 8080 in Docker)
# PORT=8080

# Node environment (development | production)
# NODE_ENV=production

# =============================================================================
# Data Persistence
# =============================================================================

# The application supports two database backends:
#   1. PostgreSQL (recommended for multi-pod/production deployments)
#   2. SQLite (for development or single-pod deployments)
#
# PostgreSQL is used if DATABASE_URL or POSTGRES_HOST is set. Otherwise, SQLite.

# PostgreSQL connection - Option 1: Full URL
# DATABASE_URL=postgresql://retrogemini:password@postgresql:5432/retrogemini

# PostgreSQL connection - Option 2: Individual variables (for K8s/OpenShift secrets)
# POSTGRES_HOST=postgresql
# POSTGRES_PORT=5432
# POSTGRES_USER=retrogemini
# POSTGRES_PASSWORD=password
# POSTGRES_DB=retrogemini

# SQLite database path (used when DATABASE_URL is not set)
# The server tries these locations in order:
#   1. DATA_STORE_PATH (if set)
#   2. /data/data.sqlite (for mounted volumes)
#   3. /tmp/data.sqlite (ephemeral fallback - data lost on restart!)
#   4. ./data.sqlite (local file)
#
# For single-pod production, mount a persistent volume at /data
# DATA_STORE_PATH=/data/data.sqlite

# =============================================================================
# Email Configuration (Optional)
# =============================================================================

# SMTP server for sending invitation emails
# If not configured, email invitations are disabled (link sharing still works)

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-username
# SMTP_PASS=your-password
# FROM_EMAIL=noreply@example.com

# =============================================================================
# Wi-Fi QR Code (Optional)
# =============================================================================

# When both WIFI_SSID and WIFI_PASSWORD are set, a "WI-FI" tab appears in the
# invite modal showing a QR code that participants can scan to connect to the
# local network. Useful for air-gapped or internal deployments where users
# must join a specific Wi-Fi network to access the application.

# WIFI_SSID=RetroGemini-Network
# WIFI_PASSWORD=your-wifi-password

# =============================================================================
# Corporate Proxy Configuration (Optional)
# =============================================================================

# HTTP/HTTPS proxy settings for outbound connections
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.internal.domain

# =============================================================================
# TLS/SSL Configuration (Optional)
# =============================================================================

# Custom CA certificates for corporate MITM proxies
# Point to a PEM file containing your organization's CA certificate(s)
# NODE_EXTRA_CA_CERTS=/path/to/corporate-ca.crt

# WARNING: Only use this in development environments!
# Disables TLS certificate verification (insecure)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# =============================================================================
# Security Configuration (Optional)
# =============================================================================

# Password to enable super admin panel and API endpoints (disabled if unset)
# SUPER_ADMIN_PASSWORD=change-me

# Restrict WebSocket CORS to specific origin(s)
# Default: "*" (allow all origins - suitable for self-hosted deployments)
# For production behind a known domain, set to your application URL
# CORS_ORIGIN=https://retro.example.com

# =============================================================================
# Data Backup Configuration (Optional)
# =============================================================================

# Enable automatic server-side backups (default: true)
# BACKUP_ENABLED=true

# Hours between automatic backups (default: 24)
# BACKUP_INTERVAL_HOURS=24

# Maximum number of automatic backups to keep (protected backups don't count) (default: 7)
# BACKUP_MAX_COUNT=7

# Create a backup snapshot when the server starts (default: true)
# BACKUP_ON_STARTUP=true

# =============================================================================
# Feedback Automation (Optional)
# =============================================================================

# Enable automatic GitHub dispatch when a new feedback is submitted
# FEEDBACK_AUTOMATION_ENABLED=false

# Target repository for repository_dispatch (format: owner/repo)
# FEEDBACK_AUTOMATION_GITHUB_REPO=republique-et-canton-de-geneve/RetroGemini

# GitHub token with permission to dispatch workflows on target repo
# FEEDBACK_AUTOMATION_GITHUB_TOKEN=ghp_xxx

# Dispatch event type listened by workflow (default: feedback_hub_submission)
# FEEDBACK_AUTOMATION_EVENT_TYPE=feedback_hub_submission

# Minimum title length to auto-run (shorter feedbacks request clarification)
# FEEDBACK_AUTOMATION_MIN_TITLE_LENGTH=8

# Minimum description length to auto-run (default: 40)
# FEEDBACK_AUTOMATION_MIN_DESCRIPTION_LENGTH=40
